; Example systemd unit for running Claude Code as a service with the
; Teams channel enabled. Substitute placeholders and copy to
; /etc/systemd/system/claude-channel-teams.service (system) or
; ~/.config/systemd/user/claude-channel-teams.service (user).
;
; This is a *bridge* setup: Claude Code runs detached, the Teams channel
; routes inbound messages into the long-lived session, and Claude works
; against the configured working directory.
;
; Reverse-proxy / TLS termination is a separate unit — your standard
; nginx / caddy service, configured per docs/installation.md.

[Unit]
Description=Claude Code with Microsoft Teams channel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=<service-user>
Group=<service-group>
WorkingDirectory=<working-directory>

; Path to the Claude Code binary on this host.
ExecStart=/usr/local/bin/claude \
  --channels plugin:teams@<your-marketplace>

; Until this plugin is on the Anthropic approved list, swap in:
; ExecStart=/usr/local/bin/claude \
;   --dangerously-load-development-channels plugin:teams@<your-marketplace>

Restart=on-failure
RestartSec=10

; Logs go to the journal.
StandardOutput=journal
StandardError=journal

; Light hardening — adjust to your environment.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=<working-directory> %h/.claude

[Install]
WantedBy=multi-user.target
