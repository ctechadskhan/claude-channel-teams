# Microsoft Teams channel plugin — environment variables
#
# Copy this file to ~/.claude/channels/teams/.env once installed, then fill in
# the values from your Azure Bot Service registration. The plugin loads that
# file on boot (real shell environment wins).
#
# Real values are credentials. Never commit them.

# ── Required ────────────────────────────────────────────────────────────────

# App (client) ID of the Entra ID application backing your Teams bot.
# Found in the Azure portal under "App registrations" → your app → Overview.
TEAMS_BOT_APP_ID=<app-id-guid>

# Client secret for the same app registration.
# Created under "Certificates & secrets". Treat as a high-value credential —
# rotation cadence is a function of your tenant's secret policy.
TEAMS_BOT_APP_PASSWORD=<client-secret>

# Authentication mode. One of:
#   MultiTenant         — accept tokens issued by any Entra ID tenant
#   SingleTenant        — accept tokens from a specific tenant only (recommended)
#   UserAssignedMSI     — managed identity (advanced; see docs/azure-setup.md)
TEAMS_BOT_APP_TYPE=SingleTenant

# Required when TEAMS_BOT_APP_TYPE=SingleTenant.
# The tenant GUID that owns the bot registration. Found on the same overview page.
TEAMS_BOT_TENANT_ID=<tenant-id-guid>

# ── HTTP listener ───────────────────────────────────────────────────────────

# Address and port the plugin's HTTPS listener binds to. The Bot Framework
# service POSTs activities here.
#
# In production this is reached via a reverse proxy / public hostname; the
# plugin itself only listens on this local address. See docs/architecture.md.
TEAMS_BOT_LISTEN_HOST=127.0.0.1
TEAMS_BOT_LISTEN_PORT=3978

# Public messaging endpoint URL configured against the Azure Bot resource.
# Optional — used for diagnostics and the /teams:configure status output.
# Example: https://teams-bot.example.com/api/messages
TEAMS_BOT_ENDPOINT_URL=<public-https-endpoint>

# ── Optional ────────────────────────────────────────────────────────────────

# Override the on-disk state directory. Default: ~/.claude/channels/teams
# Use this to run multiple isolated bots on the same host.
# TEAMS_STATE_DIR=

# When set, snapshot access policy at boot and never re-read or write it.
# Pairing is downgraded to allowlist in this mode (see docs/pairing.md).
# TEAMS_ACCESS_MODE=static
